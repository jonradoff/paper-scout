# MongoDB connection string (required)
MONGODB_URI=mongodb://localhost:27017
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/

# Database name
DB_NAME=paper_scout

# Semantic Scholar API key (optional but recommended — improves citation data)
# Get one free at https://www.semanticscholar.org/product/api
S2_API_KEY=

# Hugging Face token (optional — for HF Daily Papers access)
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=

# Fetch settings
FETCH_WINDOW_HOURS=24
ARXIV_MAX_RESULTS=200

# arXiv categories to monitor (comma-separated)
# Full list: https://arxiv.org/category_taxonomy
# ARXIV_CATEGORIES=cs.AI,cs.CL,cs.LG,cs.MA,cs.CR,cs.SE

# Scoring weights (must sum to 1.0)
WEIGHT_EMBEDDING=0.45
WEIGHT_KEYWORD=0.15
WEIGHT_CITATION=0.20
WEIGHT_COMMUNITY=0.10
WEIGHT_RECENCY=0.10
CANDIDATE_THRESHOLD=0.20

# Keyword sub-weights
KEYWORD_HIGH_WEIGHT=1.0
KEYWORD_MEDIUM_WEIGHT=0.6
KEYWORD_LOW_WEIGHT=0.3
KEYWORD_TITLE_BOOST=1.5

# Scheduling (cron-based: run once daily at this hour/minute in this timezone)
SCHEDULE_CRON_HOUR=5
SCHEDULE_CRON_MINUTE=0
SCHEDULE_TIMEZONE=America/New_York

# Model cache directory
MODEL_CACHE_DIR=./model_cache

# Embedding model
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Paper TTL (days before auto-deleting non-candidate papers)
PAPER_TTL_DAYS=30
